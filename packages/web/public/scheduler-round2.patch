+                aria-invalid={nameTrimmed.length > 0 && !nameValid}
+                className={`rounded bg-zinc-800 px-2 py-1.5 text-xs text-zinc-200 border outline-none ${
+                  nameTrimmed.length > 0 && !nameValid
+                    ? 'border-red-600 focus:border-red-500'
