+    expect(skipped[0]?.error).toContain('maxConcurrent');
+
+    // Cleanup: drain in-flight runs before stopping the scheduler.
+    inFlight.forEach((r) => r());
+    await new Promise((r) => setTimeout(r, 20));
+    scheduler.stop();
+  });
