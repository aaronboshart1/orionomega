{
  "name": "orionomega",
  "version": "0.1.0",
  "private": true,
  "description": "OrionOmega — Lightweight AI Agent Orchestration System",
  "author": "Aaron Boshart",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "clean": "rm -rf packages/*/dist",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "koffi",
      "sharp"
    ]
  }
}
