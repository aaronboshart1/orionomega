{
  "$schema": "https://orionomega.dev/schemas/skill-manifest.v1.json",
  "name": "atlassian",
  "version": "1.0.0",
  "description": "Full-featured Atlassian Cloud integration via the official Rovo MCP Server. Manage Jira issues, Confluence pages, Compass components, JSM alerts, and Bitbucket repositories. Supports OAuth 2.1 and API token authentication with per-product enablement.",
  "author": "OrionOmega",
  "license": "MIT",
  "homepage": "https://github.com/aaronboshart1/orionomega",
  "repository": "https://github.com/aaronboshart1/orionomega",
  "orionomega": ">=0.1.0",
  "os": ["linux", "darwin", "win32"],
  "requires": {
    "commands": [],
    "env": [],
    "skills": []
  },
  "setup": {
    "required": true,
    "description": "Authenticate with Atlassian Cloud to access Jira, Confluence, Compass, JSM, and Bitbucket via the Rovo MCP Server.",
    "auth": {
      "methods": [
        {
          "type": "oauth",
          "label": "OAuth 2.1 (recommended)",
          "description": "Use the Atlassian OAuth 2.1 flow for interactive, user-driven access. Requires a browser to complete the consent screen. Supports all Rovo MCP Server tools.",
          "tokenUrl": "https://id.atlassian.com/manage-profile/security/api-tokens"
        },
        {
          "type": "api-key",
          "label": "Personal API Token (Basic auth)",
          "description": "Use a personal API token for headless/unattended access. Base64-encode email:token. Some tools (e.g. Compass) may be unavailable.",
          "tokenUrl": "https://id.atlassian.com/manage-profile/security/api-tokens",
          "envVar": "ATLASSIAN_API_TOKEN",
          "validateCommand": "node -e \"const t=process.env.ATLASSIAN_API_TOKEN||'';const h=t.includes(':')?(Buffer.from(t).toString('base64'))===t?'Basic '+t:'Basic '+Buffer.from(t).toString('base64'):'Bearer '+t;fetch('https://mcp.atlassian.com/v1/mcp',{method:'POST',headers:{'Content-Type':'application/json',Authorization:h}}).then(r=>{process.exit(r.status<500?0:1)}).catch(()=>process.exit(1))\""
        }
      ]
    },
    "handler": "hooks/setup.js"
  },
  "triggers": {
    "keywords": [
      "atlassian", "jira", "confluence", "compass", "bitbucket",
      "jsm", "jira service management", "sprint", "epic", "story",
      "jql", "cql", "confluence page", "jira issue", "jira ticket",
      "backlog", "kanban", "scrum", "rovo"
    ],
    "patterns": [
      "\\batlassian\\b",
      "\\bjira\\b",
      "\\bconfluence\\b",
      "\\bcompass\\b",
      "\\bbitbucket\\b",
      "\\b[A-Z]{2,10}-\\d+\\b",
      "\\b(create|open|close|assign|search|find|list|update|transition)\\s+(issue|ticket|page|story|bug|epic|task)\\b",
      "\\bjql\\b",
      "\\bcql\\b"
    ],
    "commands": ["/atlassian", "/jira", "/confluence"]
  },
  "tools": [
    {
      "name": "atlassian_jira",
      "description": "Manage Jira issues: get, create, edit, transition, comment, search via JQL, list projects and issue types. Covers read_jira, write_jira, and search_jira permission groups.",
      "handler": "handlers/atlassian_jira.js",
      "timeout": 60000,
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "get_issue", "create_issue", "edit_issue", "transition_issue",
              "add_comment", "add_worklog", "search_jql",
              "list_projects", "get_issue_types", "get_transitions",
              "get_link_types", "get_remote_links", "lookup_user",
              "get_field_metadata"
            ],
            "description": "Jira action to perform"
          },
          "issue_key": {
            "type": "string",
            "description": "Jira issue key (e.g. 'PROJ-123') for get/edit/transition/comment"
          },
          "project_key": {
            "type": "string",
            "description": "Jira project key (e.g. 'PROJ') for create/list operations"
          },
          "issue_type": {
            "type": "string",
            "description": "Issue type name (e.g. 'Story', 'Bug', 'Task', 'Epic') for create"
          },
          "summary": {
            "type": "string",
            "description": "Issue summary/title for create/edit"
          },
          "description": {
            "type": "string",
            "description": "Issue description (ADF or plain text) for create/edit"
          },
          "fields": {
            "type": "object",
            "description": "Additional fields to set (for create/edit). Keys are field IDs or names."
          },
          "transition_id": {
            "type": "string",
            "description": "Workflow transition ID (for transition_issue)"
          },
          "comment": {
            "type": "string",
            "description": "Comment body text (for add_comment)"
          },
          "time_spent": {
            "type": "string",
            "description": "Time spent (e.g. '2h 30m') for add_worklog"
          },
          "jql": {
            "type": "string",
            "description": "JQL query string (for search_jql)"
          },
          "max_results": {
            "type": "number",
            "description": "Maximum results to return (default 10)"
          },
          "query": {
            "type": "string",
            "description": "User name or email to look up (for lookup_user)"
          },
          "cloud_id": {
            "type": "string",
            "description": "Atlassian Cloud site ID. If omitted, uses the default from settings."
          }
        },
        "required": ["action"]
      }
    },
    {
      "name": "atlassian_confluence",
      "description": "Manage Confluence pages and spaces: get, create, update pages, list spaces, search via CQL, manage comments. Covers read_confluence, write_confluence, and search_confluence permission groups.",
      "handler": "handlers/atlassian_confluence.js",
      "timeout": 60000,
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "get_page", "create_page", "update_page",
              "get_descendants", "list_spaces", "list_pages_in_space",
              "search_cql",
              "get_footer_comments", "get_inline_comments", "get_comment_children",
              "create_footer_comment", "create_inline_comment"
            ],
            "description": "Confluence action to perform"
          },
          "page_id": {
            "type": "string",
            "description": "Confluence page ID (for get/update/comments)"
          },
          "space_id": {
            "type": "string",
            "description": "Confluence space ID (for list_pages_in_space)"
          },
          "space_key": {
            "type": "string",
            "description": "Confluence space key (for create_page)"
          },
          "parent_page_id": {
            "type": "string",
            "description": "Parent page ID (for create_page, get_descendants)"
          },
          "title": {
            "type": "string",
            "description": "Page title (for create/update)"
          },
          "body": {
            "type": "string",
            "description": "Page body content in storage format or wiki markup (for create/update)"
          },
          "comment_text": {
            "type": "string",
            "description": "Comment text (for create_footer_comment/create_inline_comment)"
          },
          "comment_id": {
            "type": "string",
            "description": "Comment ID (for get_comment_children)"
          },
          "inline_text_selection": {
            "type": "string",
            "description": "Text selection to anchor inline comment to"
          },
          "cql": {
            "type": "string",
            "description": "CQL query string (for search_cql)"
          },
          "max_results": {
            "type": "number",
            "description": "Maximum results to return (default 10)"
          },
          "cloud_id": {
            "type": "string",
            "description": "Atlassian Cloud site ID. If omitted, uses the default from settings."
          }
        },
        "required": ["action"]
      }
    },
    {
      "name": "atlassian_compass",
      "description": "Manage Compass components: get, create, list, search, view activity, labels, types, relationships, and custom fields. Requires OAuth 2.1 authentication.",
      "handler": "handlers/atlassian_compass.js",
      "timeout": 60000,
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "get_component", "list_components", "create_component",
              "get_activity", "get_labels", "get_types",
              "get_custom_fields", "get_my_team_components",
              "create_relationship", "create_custom_field"
            ],
            "description": "Compass action to perform"
          },
          "component_id": {
            "type": "string",
            "description": "Compass component ID"
          },
          "name": {
            "type": "string",
            "description": "Component name (for create)"
          },
          "type": {
            "type": "string",
            "description": "Component type (for create/filter)"
          },
          "query": {
            "type": "string",
            "description": "Search query for listing components"
          },
          "fields": {
            "type": "object",
            "description": "Additional fields for create/custom field operations"
          },
          "source_id": {
            "type": "string",
            "description": "Source component ID (for create_relationship)"
          },
          "target_id": {
            "type": "string",
            "description": "Target component ID (for create_relationship)"
          },
          "relationship_type": {
            "type": "string",
            "description": "Relationship type (for create_relationship)"
          },
          "max_results": {
            "type": "number",
            "description": "Maximum results to return (default 10)"
          },
          "cloud_id": {
            "type": "string",
            "description": "Atlassian Cloud site ID. If omitted, uses the default from settings."
          }
        },
        "required": ["action"]
      }
    },
    {
      "name": "atlassian_jsm",
      "description": "Manage Jira Service Management operations: get alerts, list on-call schedules, view teams, update alert status. Requires API token authentication.",
      "handler": "handlers/atlassian_jsm.js",
      "timeout": 60000,
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "get_alert", "search_alerts",
              "get_schedule", "list_schedules",
              "get_team", "list_teams",
              "update_alert"
            ],
            "description": "JSM Ops action to perform"
          },
          "alert_id": {
            "type": "string",
            "description": "Alert ID or alias"
          },
          "query": {
            "type": "string",
            "description": "Search query for alerts"
          },
          "schedule_id": {
            "type": "string",
            "description": "On-call schedule ID"
          },
          "team_id": {
            "type": "string",
            "description": "Operations team ID"
          },
          "alert_action": {
            "type": "string",
            "enum": ["acknowledge", "unacknowledge", "close", "escalate"],
            "description": "Alert action to perform (for update_alert)"
          },
          "max_results": {
            "type": "number",
            "description": "Maximum results to return (default 10)"
          },
          "cloud_id": {
            "type": "string",
            "description": "Atlassian Cloud site ID. If omitted, uses the default from settings."
          }
        },
        "required": ["action"]
      }
    },
    {
      "name": "atlassian_bitbucket",
      "description": "Manage Bitbucket Cloud repositories, pull requests, pipelines, and deployments. Requires API token authentication with Bitbucket scopes.",
      "handler": "handlers/atlassian_bitbucket.js",
      "timeout": 60000,
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "list_workspaces", "get_workspace",
              "list_repos", "get_repo", "get_default_reviewers",
              "list_pull_requests", "get_pull_request", "get_pr_diff", "get_pr_comments",
              "create_pull_request", "merge_pull_request", "approve_pull_request", "comment_on_pr",
              "get_branch", "get_commit", "list_files",
              "create_branch", "create_commit",
              "list_pipelines", "get_pipeline", "get_pipeline_steps", "get_step_log", "run_pipeline",
              "list_deployments", "get_deployment",
              "list_environments", "create_environment", "update_environment", "delete_environment",
              "my_pull_requests"
            ],
            "description": "Bitbucket action to perform"
          },
          "workspace": {
            "type": "string",
            "description": "Bitbucket workspace slug"
          },
          "repo_slug": {
            "type": "string",
            "description": "Repository slug"
          },
          "pr_id": {
            "type": "string",
            "description": "Pull request ID"
          },
          "branch": {
            "type": "string",
            "description": "Branch name"
          },
          "commit_hash": {
            "type": "string",
            "description": "Commit hash"
          },
          "title": {
            "type": "string",
            "description": "PR or environment title"
          },
          "description": {
            "type": "string",
            "description": "PR or environment description"
          },
          "source_branch": {
            "type": "string",
            "description": "Source branch for PR creation"
          },
          "destination_branch": {
            "type": "string",
            "description": "Destination branch for PR creation (default: main)"
          },
          "comment": {
            "type": "string",
            "description": "Comment text"
          },
          "pipeline_id": {
            "type": "string",
            "description": "Pipeline UUID"
          },
          "step_id": {
            "type": "string",
            "description": "Pipeline step UUID"
          },
          "environment_id": {
            "type": "string",
            "description": "Deployment environment UUID"
          },
          "deployment_id": {
            "type": "string",
            "description": "Deployment UUID"
          },
          "files": {
            "type": "object",
            "description": "Files to commit: { 'path/to/file': 'content' }"
          },
          "commit_message": {
            "type": "string",
            "description": "Commit message (for create_commit)"
          },
          "max_results": {
            "type": "number",
            "description": "Maximum results to return (default 10)"
          },
          "cloud_id": {
            "type": "string",
            "description": "Atlassian Cloud site ID. If omitted, uses the default from settings."
          }
        },
        "required": ["action"]
      }
    },
    {
      "name": "atlassian_search",
      "description": "Cross-product Atlassian search and Teamwork Graph queries. Search across Jira and Confluence using natural language (Rovo), or traverse the Teamwork Graph for connected context.",
      "handler": "handlers/atlassian_search.js",
      "timeout": 60000,
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "search", "fetch",
              "get_context", "get_object",
              "get_user_info", "list_resources"
            ],
            "description": "Search/platform action to perform"
          },
          "query": {
            "type": "string",
            "description": "Natural language search query (for search)"
          },
          "ari": {
            "type": "string",
            "description": "Atlassian Resource Identifier (for fetch/get_object)"
          },
          "aris": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Multiple ARIs (for get_object batch)"
          },
          "entity_ari": {
            "type": "string",
            "description": "Entity ARI to get connected context for (for get_context)"
          },
          "max_results": {
            "type": "number",
            "description": "Maximum results to return (default 10)"
          },
          "cloud_id": {
            "type": "string",
            "description": "Atlassian Cloud site ID. If omitted, uses the default from settings."
          }
        },
        "required": ["action"]
      }
    }
  ],
  "workerProfile": {
    "tools": [
      "atlassian_jira", "atlassian_confluence", "atlassian_compass",
      "atlassian_jsm", "atlassian_bitbucket", "atlassian_search"
    ],
    "maxTimeout": 120000
  },
  "settings": {
    "type": "object",
    "properties": {
      "auth_method": {
        "type": "select",
        "label": "Authentication Method",
        "description": "How to authenticate with Atlassian Cloud. OAuth 2.1 supports all tools; API token may have limited tool availability.",
        "options": [
          { "value": "oauth", "label": "OAuth 2.1 (recommended)" },
          { "value": "basic", "label": "Personal API Token (Basic auth)" },
          { "value": "bearer", "label": "Service Account API Key (Bearer token)" }
        ],
        "default": "oauth",
        "required": true,
        "group": "auth",
        "order": 1
      },
      "oauth_token": {
        "type": "password",
        "label": "OAuth 2.1 Access Token",
        "description": "OAuth access token obtained from the Atlassian OAuth 2.1 authorization flow.",
        "placeholder": "eyJhbGciOiJSUzI1NiIs...",
        "required": false,
        "group": "auth",
        "widget": "secret",
        "order": 2,
        "dependsOn": { "field": "auth_method", "value": "oauth" }
      },
      "api_email": {
        "type": "string",
        "label": "Atlassian Account Email",
        "description": "The email address associated with your Atlassian account (required for Basic auth).",
        "placeholder": "you@company.com",
        "required": false,
        "group": "auth",
        "order": 3,
        "dependsOn": { "field": "auth_method", "value": "basic" }
      },
      "api_token": {
        "type": "password",
        "label": "Personal API Token",
        "description": "Personal API token from id.atlassian.com/manage-profile/security/api-tokens",
        "placeholder": "ATATT3xF...",
        "required": false,
        "group": "auth",
        "widget": "secret",
        "order": 4,
        "dependsOn": { "field": "auth_method", "values": ["basic", "bearer"] }
      },
      "default_cloud_id": {
        "type": "string",
        "label": "Default Cloud ID / Site URL",
        "description": "Your Atlassian Cloud site URL (e.g. 'https://yoursite.atlassian.net') or cloudId. Used when cloud_id is not passed per-call.",
        "placeholder": "https://mycompany.atlassian.net",
        "required": false,
        "group": "preferences",
        "order": 5
      },
      "default_jira_project": {
        "type": "string",
        "label": "Default Jira Project Key",
        "description": "Jira project key to use when none is specified (e.g. 'PROJ').",
        "placeholder": "PROJ",
        "required": false,
        "group": "preferences",
        "order": 6
      },
      "default_confluence_space": {
        "type": "string",
        "label": "Default Confluence Space",
        "description": "Confluence space key or ID to use when none is specified.",
        "placeholder": "TEAM",
        "required": false,
        "group": "preferences",
        "order": 7
      },
      "enable_jira": {
        "type": "boolean",
        "label": "Enable Jira",
        "description": "Enable Jira issue management tools (read, write, search).",
        "default": true,
        "group": "preferences",
        "order": 10
      },
      "enable_confluence": {
        "type": "boolean",
        "label": "Enable Confluence",
        "description": "Enable Confluence page and space management tools.",
        "default": true,
        "group": "preferences",
        "order": 11
      },
      "enable_compass": {
        "type": "boolean",
        "label": "Enable Compass",
        "description": "Enable Compass component management tools. Requires OAuth 2.1.",
        "default": false,
        "group": "preferences",
        "order": 12
      },
      "enable_jsm": {
        "type": "boolean",
        "label": "Enable Jira Service Management",
        "description": "Enable JSM Ops tools (alerts, schedules, teams). Requires API token auth.",
        "default": false,
        "group": "preferences",
        "order": 13
      },
      "enable_bitbucket": {
        "type": "boolean",
        "label": "Enable Bitbucket",
        "description": "Enable Bitbucket Cloud tools (repos, PRs, pipelines). Requires API token auth with Bitbucket scopes.",
        "default": false,
        "group": "preferences",
        "order": 14
      },
      "enable_search": {
        "type": "boolean",
        "label": "Enable Cross-Product Search",
        "description": "Enable Rovo cross-product search and Teamwork Graph tools.",
        "default": true,
        "group": "preferences",
        "order": 15
      },
      "max_results": {
        "type": "number",
        "label": "Default Max Results",
        "description": "Default maximum results for search/list operations (1-50).",
        "default": 10,
        "group": "advanced",
        "order": 20
      },
      "mcp_endpoint": {
        "type": "url",
        "label": "MCP Server Endpoint",
        "description": "Atlassian Rovo MCP Server endpoint. Only change if using a custom proxy.",
        "default": "https://mcp.atlassian.com/v1/mcp",
        "placeholder": "https://mcp.atlassian.com/v1/mcp",
        "required": false,
        "group": "advanced",
        "order": 21
      }
    }
  },
  "hooks": {
    "healthCheck": "hooks/health.js",
    "postInstall": "hooks/setup.js"
  }
}
