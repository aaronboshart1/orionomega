# OrionOmega — environment variable reference
#
# These variables are read directly by the application at runtime.
# Most configuration lives in ~/.orionomega/config.yaml; env vars are used
# for secrets, deployment overrides, and CI/CD environments.
#
# Copy relevant variables to your shell profile or a .env file loaded by
# your process manager. Never commit real values to source control.

# ─── Required ────────────────────────────────────────────────────────────────

# Your Anthropic API key. Required to run any agent.
# Get one at https://console.anthropic.com/
# Alternatively, set models.apiKey in config.yaml (not recommended for shared machines).
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ────────────────────────────────────────────────────────────────

# API key for your Hindsight memory server.
# Required only if your Hindsight instance has authentication enabled.
# See https://github.com/aaronboshart1/hindsight for server setup.
# HINDSIGHT_API_KEY=

# Override the config file path. Useful for running multiple isolated instances
# or in CI without a home directory.
# Defaults to ~/.orionomega/config.yaml (or $CWD/.orionomega on Replit).
# CONFIG_PATH=

# Override the minimum log level at runtime without editing config.yaml.
# Values: error | warn | info | verbose | debug
# ORIONOMEGA_LOG_LEVEL=info

# Delay in milliseconds before the gateway attempts a restart after a crash.
# Useful to back off during rapid restart loops.
# ORIONOMEGA_RESTART_DELAY=1000

# ─── Web UI (Next.js) ────────────────────────────────────────────────────────

# Host and port for the Next.js development server.
# These override webui.bind and webui.port in config.yaml.
# HOST=127.0.0.1
# PORT=5000

# Injected into the web UI at build time for display purposes.
# Set by your CI pipeline — not needed for local development.
# NEXT_PUBLIC_APP_VERSION=0.1.0
# NEXT_PUBLIC_GIT_HASH=

# ─── Skills ──────────────────────────────────────────────────────────────────

# GitHub authentication for the built-in github skill.
# The skill uses the `gh` CLI; set GH_TOKEN if running in a headless environment.
# GH_TOKEN=

# GitHub OAuth client ID (only needed if you configure your own OAuth app).
# GH_OAUTH_CLIENT_ID=

# ─── System (read-only, set by the OS) ───────────────────────────────────────
# These are standard OS variables the application reads for context.
# You do not need to set them; they are documented here for reference.
#
# EDITOR / VISUAL — preferred text editor, used by `orionomega config`
# HOME            — home directory, base for default config/log paths
# PATH            — used to locate skill handler scripts and CLI tools
# SHELL           — shell used when spawning subprocesses
# TERM            — terminal type, affects TUI rendering
# USER            — current user, used in log metadata
# LANG            — locale, affects character encoding in skill output
#
# REPL_ID         — set automatically by Replit; shifts data dir to $CWD/.orionomega
